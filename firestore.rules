rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Helper functions ───────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdminOrManager() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager']
      );
    }

    function isModerator() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'moderator']
      );
    }

    function isAuditor() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'auditor']
      );
    }

    function isStaff() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'moderator', 'auditor']
      );
    }

    function isTeacher() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('userType', '') == 'teacher';
    }

    // verificationStatus 필드가 없으면 grandfathered 처리 (기존 사용자 호환)
    function isVerified() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('verificationStatus', 'verified') == 'verified';
    }

    function isNotSuspended() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('suspendedUntil', null) == null ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.suspendedUntil < request.time
      );
    }

    // 인증 + 비정지 (글/댓글/신고/투표/북마크 작성 가드)
    function canWrite() {
      return isVerified() && isNotSuspended();
    }

    function noScript(value) {
      return !value.matches('.*<[sS][cC][rR][iI][pP][tT].*');
    }

    // 변경된 필드만 추출
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // posts 인터랙션 필드 (작성자 외에 변경 가능)
    function isInteractionUpdate() {
      return changedKeys().hasOnly(
        ['likes', 'dislikes', 'likeCount', 'dislikeCount', 'pollVoters', 'commentCount', 'anonymousMapping', 'anonymousCount', 'bookmarkedBy']
      );
    }

    // 카운터 증감 검증 (-1 ~ +1, 기존 필드 없을 시 0으로 간주)
    function validCounterDelta(field) {
      return !(field in changedKeys()) || (
        request.resource.data[field] is int &&
        request.resource.data[field] >= 0 &&
        request.resource.data[field] - resource.data.get(field, 0) >= -1 &&
        request.resource.data[field] - resource.data.get(field, 0) <= 1
      );
    }

    // ── users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdminOrManager());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
          request.resource.data.get('role', 'user') == resource.data.get('role', 'user') &&
          request.resource.data.get('suspendedUntil', null) == resource.data.get('suspendedUntil', null) &&
          request.resource.data.get('approved', false) == resource.data.get('approved', false)) ||
        isAdminOrManager()
      );
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      match /subjects/{doc} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /sync/{doc} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /notifications/{notifId} {
        allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
        // notifications는 Cloud Functions가 생성하지만, 클라이언트 직접 생성도 허용 (관리자 알림 등)
        allow create: if isSignedIn();
      }
    }

    // ── posts ──────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;

      allow create: if canWrite() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 200 &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 5000 &&
        noScript(request.resource.data.title) &&
        noScript(request.resource.data.content);

      // 작성자만 자유 수정 (admin/manager도 글 수정 불가, 삭제는 가능)
      // 그 외는 인터랙션 필드만 + 카운터 증감 검증
      // 매니저는 공지 고정/해제 가능 (isPinned, pinnedAt)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.authorUid ||
        (
          isInteractionUpdate() &&
          validCounterDelta('likeCount') &&
          validCounterDelta('dislikeCount') &&
          validCounterDelta('commentCount')
        ) ||
        (
          isAdminOrManager() &&
          changedKeys().hasOnly(['isPinned', 'pinnedAt'])
        ) ||
        (
          isModerator() &&
          changedKeys().hasOnly(['isHidden', 'deletedAt', 'deletedBy']) &&
          request.resource.data.isHidden == true
        )
      );

      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.authorUid || isModerator()
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if canWrite() &&
          request.resource.data.authorUid == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() > 0 &&
          request.resource.data.content.size() <= 1000 &&
          noScript(request.resource.data.content) &&
          (
            !('mentions' in request.resource.data) ||
            (request.resource.data.mentions is list &&
             request.resource.data.mentions.size() <= 20)
          );
        allow delete: if isSignedIn() && (
          request.auth.uid == resource.data.authorUid || isModerator()
        );
        // 모더는 자유 수정 / 작성자는 본인 댓글 소프트 삭제만
        allow update: if isModerator() || (
          isSignedIn() &&
          request.auth.uid == resource.data.authorUid &&
          changedKeys().hasOnly(['isHidden', 'deletedAt', 'deletedBy']) &&
          request.resource.data.isHidden == true
        );
      }
    }

    // ── reports ────────────────────────────────────────────────────────
    match /reports/{reportId} {
      // 인증 + 비정지 사용자만 신고 가능 (어뷰징 방지)
      allow create: if canWrite() &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() > 0 &&
        request.resource.data.reason.size() <= 200 &&
        noScript(request.resource.data.reason);
      allow read: if isStaff();
      allow delete: if isAdminOrManager();
      allow update: if false;
    }

    // ── app_config ─────────────────────────────────────────────────────
    match /app_config/{doc} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }

    // ── app_stats (집계 카운터 — Cloud Functions가 쓰기, 관리자만 읽기) ──
    match /app_stats/{doc} {
      allow read: if isAuditor();
      allow write: if false;
    }

    // ── admin_logs ─────────────────────────────────────────────────────
    match /admin_logs/{logId} {
      allow create: if isModerator();
      allow read: if isStaff();
      allow update, delete: if false;
    }

    // ── chats ──────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants;
      // update: 본인이 참여자일 때만
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if canWrite() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          // 일반 메시지: senderUid 본인 일치 / 시스템 메시지: type=='system'
          (
            (request.resource.data.get('senderUid', '') == request.auth.uid) ||
            (request.resource.data.get('type', '') == 'system')
          ) &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 2000 &&
          noScript(request.resource.data.content) &&
          // imageUrl이 있으면 string, 100자 미만의 firebasestorage.googleapis.com URL이어야 함
          (
            !('imageUrl' in request.resource.data) ||
            (request.resource.data.imageUrl is string &&
             request.resource.data.imageUrl.size() < 1000)
          );

        // update는 본인 메시지의 deletedFor / deleted 필드만 수정 가능 (삭제 기능)
        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          (
            // 같이 삭제: 본인 메시지 + deleted 필드만
            (resource.data.senderUid == request.auth.uid &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted', 'deletedFor', 'content'])) ||
            // 나만 삭제: deletedFor 배열에 본인만 추가 가능
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor']) &&
             request.auth.uid in request.resource.data.deletedFor)
          );
      }
    }

    // ── function_logs ──────────────────────────────────────────────────
    match /function_logs/{logId} {
      allow read: if isAuditor();
      allow write: if false;
    }

    // ── crash_logs ─────────────────────────────────────────────────────
    match /crash_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAuditor();
      allow update, delete: if isAdminOrManager();
    }

    // ── feedbacks ──────────────────────────────────────────────────────
    match /app_feedbacks/{feedbackId} {
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 3000 &&
        noScript(request.resource.data.content);
      allow read: if isAuditor();
      allow update, delete: if isAdminOrManager();
    }
    match /council_feedbacks/{feedbackId} {
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 3000 &&
        noScript(request.resource.data.content);
      allow read: if isAuditor();
      allow update, delete: if isAdminOrManager();
    }

    // ── studentIds (학번 점유 역색인) ──────────────────────────────────
    // Cloud Functions가 가입/탈퇴 트랜잭션으로 관리. 클라이언트는 unique 검사용 read만.
    match /studentIds/{studentId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── otp_codes (OTP 해시 + TTL 30분) ────────────────────────────────
    // Cloud Functions만 발송/검증. 클라이언트 직접 접근 차단.
    match /otp_codes/{uid} {
      allow read, write: if false;
    }

    // ── banned_devices (정지 이력 기기 추적) ────────────────────────────
    // Cloud Functions만 관리. 사용자는 본인 기기 차단 여부를 알 수 없음.
    match /banned_devices/{installationId} {
      allow read, write: if false;
    }

    // ── reports_queue (신고 5명 임계 시 자동 등록) ──────────────────────
    // Cloud Functions가 aggregate로 작성. moderator 이상이 큐 조회.
    // 신고자 식별 정보(reporters)는 admin만 접근 (앱 단에서 마스킹).
    match /reports_queue/{postId} {
      allow read: if isStaff();
      allow write: if false;
    }

    // ── appeals (이의제기) ─────────────────────────────────────────────
    // 정지된 사용자가 본인 uid로 작성 가능 (canWrite 우회). admin/manager가 처리.
    match /appeals/{appealId} {
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() > 0 &&
        request.resource.data.reason.size() <= 500 &&
        noScript(request.resource.data.reason);
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.uid || isStaff()
      );
      allow update: if isAdminOrManager() &&
        changedKeys().hasOnly(['status', 'reviewedBy', 'reviewedAt', 'reviewerNote']);
      allow delete: if false;
    }

    // ── data_requests (개인정보 이전 요구) ──────────────────────────────
    // 본인 uid로 신청, Cloud Functions가 처리 후 상태 업데이트.
    match /data_requests/{requestId} {
      allow create: if canWrite() &&
        request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.uid || isAdminOrManager()
      );
      allow update, delete: if false;
    }

    // ── teacher_invites (교사 초대링크) ─────────────────────────────────
    // admin/manager 발급, 사용자가 redeem 시 토큰 검증용으로 read.
    // 사용 횟수 차감/만료 처리는 Cloud Functions만.
    match /teacher_invites/{inviteId} {
      allow create: if isAdminOrManager() &&
        request.resource.data.maxUses is int &&
        request.resource.data.maxUses > 0 &&
        request.resource.data.expiresAt is timestamp;
      allow read: if isSignedIn();
      allow update: if false;
      allow delete: if isAdminOrManager();
    }

    // ── community_rules (커뮤니티 규정 버전 관리) ───────────────────────
    match /community_rules/{version} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }

    // ── 댓글 collection group 읽기 ─────────────────────────────────────
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }
  }
}
