rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Helper functions ───────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdminOrManager() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager']
      );
    }

    function noScript(value) {
      return !value.matches('.*<[sS][cC][rR][iI][pP][tT].*');
    }

    // 변경된 필드만 추출
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // posts 인터랙션 필드 (작성자 외에 변경 가능)
    function isInteractionUpdate() {
      return changedKeys().hasOnly(
        ['likes', 'dislikes', 'likeCount', 'dislikeCount', 'pollVoters', 'commentCount', 'anonymousMapping', 'anonymousCount', 'bookmarkedBy']
      );
    }

    // 카운터 증감 검증 (-1 ~ +1, 기존 필드 없을 시 0으로 간주)
    function validCounterDelta(field) {
      return !(field in changedKeys()) || (
        request.resource.data[field] is int &&
        request.resource.data[field] >= 0 &&
        request.resource.data[field] - resource.data.get(field, 0) >= -1 &&
        request.resource.data[field] - resource.data.get(field, 0) <= 1
      );
    }

    // ── users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdminOrManager());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
          request.resource.data.get('role', 'user') == resource.data.get('role', 'user') &&
          request.resource.data.get('suspendedUntil', null) == resource.data.get('suspendedUntil', null) &&
          request.resource.data.get('approved', false) == resource.data.get('approved', false)) ||
        isAdminOrManager()
      );
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      match /subjects/{doc} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /sync/{doc} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /notifications/{notifId} {
        allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
        // notifications는 Cloud Functions가 생성하지만, 클라이언트 직접 생성도 허용 (관리자 알림 등)
        allow create: if isSignedIn();
      }
    }

    // ── posts ──────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;

      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 200 &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 5000 &&
        noScript(request.resource.data.title) &&
        noScript(request.resource.data.content);

      // 작성자만 자유 수정 (admin/manager도 글 수정 불가, 삭제는 가능)
      // 그 외는 인터랙션 필드만 + 카운터 증감 검증
      // 매니저는 공지 고정/해제 가능 (isPinned, pinnedAt)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.authorUid ||
        (
          isInteractionUpdate() &&
          validCounterDelta('likeCount') &&
          validCounterDelta('dislikeCount') &&
          validCounterDelta('commentCount')
        ) ||
        (
          isAdminOrManager() &&
          changedKeys().hasOnly(['isPinned', 'pinnedAt'])
        )
      );

      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.authorUid || isAdminOrManager()
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() &&
          request.resource.data.authorUid == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() > 0 &&
          request.resource.data.content.size() <= 1000 &&
          noScript(request.resource.data.content) &&
          // mentions 필드는 string 배열 (uid 목록)
          (
            !('mentions' in request.resource.data) ||
            (request.resource.data.mentions is list &&
             request.resource.data.mentions.size() <= 20)
          );
        allow delete: if isSignedIn() && (
          request.auth.uid == resource.data.authorUid || isAdminOrManager()
        );
        // 댓글 update는 admin/manager만 (편집 기능 없음, soft-delete 대비)
        allow update: if isAdminOrManager();
      }
    }

    // ── reports ────────────────────────────────────────────────────────
    match /reports/{reportId} {
      // 누구나 신고 생성 가능하지만 본인 uid + reason 필수
      allow create: if isSignedIn() &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() > 0 &&
        request.resource.data.reason.size() <= 200 &&
        noScript(request.resource.data.reason);
      allow read, delete: if isAdminOrManager();
      allow update: if false;
    }

    // ── app_config ─────────────────────────────────────────────────────
    match /app_config/{doc} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }

    // ── admin_logs ─────────────────────────────────────────────────────
    match /admin_logs/{logId} {
      allow create: if isAdminOrManager();
      allow read: if isAdminOrManager();
      allow update, delete: if false;
    }

    // ── chats ──────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants;
      // update: 본인이 참여자일 때만
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          // 일반 메시지: senderUid 본인 일치 / 시스템 메시지: type=='system'
          (
            (request.resource.data.get('senderUid', '') == request.auth.uid) ||
            (request.resource.data.get('type', '') == 'system')
          ) &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 2000 &&
          noScript(request.resource.data.content) &&
          // imageUrl이 있으면 string, 100자 미만의 firebasestorage.googleapis.com URL이어야 함
          (
            !('imageUrl' in request.resource.data) ||
            (request.resource.data.imageUrl is string &&
             request.resource.data.imageUrl.size() < 1000)
          );

        // update는 본인 메시지의 deletedFor / deleted 필드만 수정 가능 (삭제 기능)
        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          (
            // 같이 삭제: 본인 메시지 + deleted 필드만
            (resource.data.senderUid == request.auth.uid &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted', 'deletedFor', 'content'])) ||
            // 나만 삭제: deletedFor 배열에 본인만 추가 가능
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor']) &&
             request.auth.uid in request.resource.data.deletedFor)
          );
      }
    }

    // ── function_logs ──────────────────────────────────────────────────
    match /function_logs/{logId} {
      allow read: if isAdminOrManager();
      allow write: if false;
    }

    // ── crash_logs ─────────────────────────────────────────────────────
    match /crash_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdminOrManager();
      allow update, delete: if isAdminOrManager();
    }

    // ── feedbacks ──────────────────────────────────────────────────────
    match /app_feedbacks/{feedbackId} {
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 3000 &&
        noScript(request.resource.data.content);
      allow read, update, delete: if isAdminOrManager();
    }
    match /council_feedbacks/{feedbackId} {
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 3000 &&
        noScript(request.resource.data.content);
      allow read, update, delete: if isAdminOrManager();
    }

    // ── 댓글 collection group 읽기 ─────────────────────────────────────
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }
  }
}
