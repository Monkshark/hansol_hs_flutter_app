rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isAdminOrManager() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager']
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdminOrManager());
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        (request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.suspendedUntil == resource.data.suspendedUntil) ||
        isAdminOrManager()
      );
      match /subjects/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /notifications/{notifId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorUid ||
        isAdminOrManager() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['likes', 'dislikes', 'pollVoters', 'commentCount', 'anonymousMapping', 'anonymousCount', 'bookmarkedBy']
        )
      );
      allow delete: if request.auth != null && (request.auth.uid == resource.data.authorUid || isAdminOrManager());
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.authorUid || isAdminOrManager());
      }
    }
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, delete: if isAdminOrManager();
    }
    match /app_config/{doc} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }
    match /admin_logs/{logId} {
      allow create: if isAdminOrManager();
      allow read: if isAdminOrManager();
    }
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      match /messages/{messageId} {
        allow read, create, update: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
    match /function_logs/{logId} {
      allow read: if isAdminOrManager();
    }
    match /crash_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if isAdminOrManager();
    }
    match /app_feedbacks/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdminOrManager();
    }
    match /council_feedbacks/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdminOrManager();
    }
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }
  }
}
